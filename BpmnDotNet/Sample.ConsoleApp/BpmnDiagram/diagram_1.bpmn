<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_191qv1h" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.23.0">
  <bpmn:process id="IdBpmnProcessingMain" name="Сканирования лидаров" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Начало процесса">
      <bpmn:outgoing>Flow_to_BlockFirstHandler</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_to_BlockFirstHandler" sourceRef="StartEvent_1" targetRef="ServiceTaskFirstHandler" />
    <bpmn:endEvent id="End_event" name="Процесс завершен">
      <bpmn:incoming>Flow_out_GatewayFourthHandler</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GatewayFirstHandler" name="Выбор типа вагона">
      <bpmn:incoming>Flow_out_BlockFirstHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_in_ReceiveTaskFirstHandle</bpmn:outgoing>
      <bpmn:outgoing>Flow_in_SendTaskFirstHandler</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_in_ReceiveTaskFirstHandle" name="Да&#10;" sourceRef="GatewayFirstHandler" targetRef="ReceiveTaskFirstHandle" />
    <bpmn:exclusiveGateway id="Gateway_Second" name="Обьединение результатов по типу вагона">
      <bpmn:incoming>Flow_out_SendTaskFirstHandler</bpmn:incoming>
      <bpmn:incoming>Flow_out_ReceiveTaskFirstHandle</bpmn:incoming>
      <bpmn:outgoing>Flow_out_Gateway_Second</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_out_SendTaskFirstHandler" sourceRef="SendTaskFirstHandler" targetRef="Gateway_Second" />
    <bpmn:sequenceFlow id="Flow_out_ReceiveTaskFirstHandle" sourceRef="ReceiveTaskFirstHandle" targetRef="Gateway_Second" />
    <bpmn:sequenceFlow id="Flow_out_BlockFirstHandler" sourceRef="ServiceTaskFirstHandler" targetRef="GatewayFirstHandler" />
    <bpmn:sequenceFlow id="Flow_in_SendTaskFirstHandler" name="Нет" sourceRef="GatewayFirstHandler" targetRef="SendTaskFirstHandler" />
    <bpmn:serviceTask id="ServiceTaskFirstHandler" name="Деление облаков на вагоны для тестироваине текст">
      <bpmn:incoming>Flow_to_BlockFirstHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_out_BlockFirstHandler</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="SendTaskFirstHandler" name="Тип_вагона_Хоппер_длинная_строка">
      <bpmn:incoming>Flow_in_SendTaskFirstHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_out_SendTaskFirstHandler</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="ReceiveTaskFirstHandle" name="Тип вагона цистерна">
      <bpmn:incoming>Flow_in_ReceiveTaskFirstHandle</bpmn:incoming>
      <bpmn:outgoing>Flow_out_ReceiveTaskFirstHandle</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:sequenceFlow id="Flow_out_Gateway_Second" sourceRef="Gateway_Second" targetRef="GatewayThirdHandler" />
    <bpmn:parallelGateway id="GatewayThirdHandler" name="Формирования репортов_подсистем">
      <bpmn:incoming>Flow_out_Gateway_Second</bpmn:incoming>
      <bpmn:outgoing>Flow_in_ServiceTaskSecondHandler</bpmn:outgoing>
      <bpmn:outgoing>Flow_in_ServiceTaskThirdHandler</bpmn:outgoing>
      <bpmn:outgoing>Flow_in_ServiceTaskFourthHandler</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_in_ServiceTaskSecondHandler" sourceRef="GatewayThirdHandler" targetRef="ServiceTaskSecondHandler" />
    <bpmn:sequenceFlow id="Flow_out_ServiceTaskSecondHandler" sourceRef="ServiceTaskSecondHandler" targetRef="GatewayFourthHandler" />
    <bpmn:parallelGateway id="GatewayFourthHandler" name="Отправка репоротов">
      <bpmn:incoming>Flow_out_ServiceTaskSecondHandler</bpmn:incoming>
      <bpmn:incoming>Flow_out_ServiceTaskThirdHandler</bpmn:incoming>
      <bpmn:incoming>Flow_out_SubProcessFirstHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_out_GatewayFourthHandler</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_in_ServiceTaskThirdHandler" sourceRef="GatewayThirdHandler" targetRef="ServiceTaskThirdHandler" />
    <bpmn:sequenceFlow id="Flow_out_ServiceTaskThirdHandler" sourceRef="ServiceTaskThirdHandler" targetRef="GatewayFourthHandler" />
    <bpmn:sequenceFlow id="Flow_out_GatewayFourthHandler" sourceRef="GatewayFourthHandler" targetRef="End_event" />
    <bpmn:sequenceFlow id="Flow_in_ServiceTaskFourthHandler" sourceRef="GatewayThirdHandler" targetRef="ServiceTaskFourthHandler" />
    <bpmn:serviceTask id="ServiceTaskSecondHandler" name="Система габаритные ворота">
      <bpmn:incoming>Flow_in_ServiceTaskSecondHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_out_ServiceTaskSecondHandler</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTaskThirdHandler" name="Система Дифекты кузова вагона">
      <bpmn:incoming>Flow_in_ServiceTaskThirdHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_out_ServiceTaskThirdHandler</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTaskFourthHandler" name="Отрицательная динамика">
      <bpmn:incoming>Flow_in_ServiceTaskFourthHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_in_SubProcessFirstHandler</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:subProcess id="SubProcessFirstHandler" name="Уточнения показателей">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_in_SubProcessFirstHandler</bpmn:incoming>
      <bpmn:outgoing>Flow_out_SubProcessFirstHandler</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_in_SubProcessFirstHandler" sourceRef="ServiceTaskFourthHandler" targetRef="SubProcessFirstHandler" />
    <bpmn:sequenceFlow id="Flow_out_SubProcessFirstHandler" sourceRef="SubProcessFirstHandler" targetRef="GatewayFourthHandler" />
    <bpmn:textAnnotation id="TextAnnotation_0mhzy78">
      <bpmn:text>1. Описание блока длинный текст

3. Выше пробел...
4. Строка номер четыре описания бескончено длинное</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1rj97am" associationDirection="None" sourceRef="ServiceTaskFirstHandler" targetRef="TextAnnotation_0mhzy78" />
    <bpmn:textAnnotation id="TextAnnotation_1eicmbs">
      <bpmn:text>Сободная аннотация. 
Строка 2
«Мой дядя самых честных правил»</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
